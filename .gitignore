

#Ignore vscode AI rules
.github/instructions/codacy.instructions.md

# macOS
.DS_Store

# Python
__pycache__/
*.pyc
.pytest_cache/
.venv/
venv/
env/

# Analysis figure binaries: SVG is the committed vector source of truth;
# the PDF/PNG renders are regenerated by the figure scripts (and, for the
# manuscript, by paper/Makefile into paper/figures/pdf/).
analysis/figures/**/*.pdf
analysis/figures/**/*.png

# Analysis cache (multi-GB DIA-NN matrices; re-downloaded from PRIDE FTP
# by the figure scripts. See MANIFEST.md for sources). Matched at any depth,
# so per-figure data/cache/ dirs are covered too.
data/

# LaTeX build artifacts + regenerable PDFs (paper/ and presentation/ keep
# their own .gitignore; these root globs are a backstop).
build/
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.log
*.nav
*.snm
*.toc
*.vrb
*.out
*.synctex.gz

# Local Claude Code config
.claude/


#Ignore cursor AI rules
.cursor/rules/codacy.mdc

# Transient collaborator share bundles (one-off exports; regenerated on demand,
# not manuscript content — e.g. ProteoBench result tarballs sent to co-authors).
*_for_vadim/
*_for_vadim.tar.gz
reports_for_vadim*/

# Standalone presentation / slides project (separate from the manuscript source).
presentation/
